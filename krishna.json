  "provisioners": [{
    "type": "shell",
  "inline": [
    "echo 'Starting setup...'",

    "sudo apt-get update -y",

    "sudo apt-get install -y openjdk-11-jdk || sudo apt-get install -y default-jdk",

    "sudo apt-get install -y maven",

    "java -version",
    "mvn -version",

    "echo 'Spring Boot environment ready'",

    "sudo waagent -force -deprovision+user && export HISTSIZE=0 && sync"
    ]
  }]
